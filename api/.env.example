# =============================================================================
# SP-MIS API — environment template
# Copy to .env (`cp .env.example .env`) then run `php artisan key:generate`.
# Defaults below are wired for the docker-compose dev stack. NO REAL SECRETS HERE.
# =============================================================================

APP_NAME="SP-MIS"
APP_ENV=local
# Generate with: php artisan key:generate. Rotate PER ENVIRONMENT (never share
# prod keys into dev/staging). NOTE: NIN/BVN are encrypted + HMAC-keyed from this
# key — rotating it requires re-encrypting/re-hashing those columns (see
# docs/SECURITY-FINDINGS.md before rotating in an environment with data).
APP_KEY=
# Keep false. Only flip to true for transient local debugging; never in shared/prod envs.
APP_DEBUG=false
# Public URL of the API.
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Password hashing cost. 12 is a sane minimum; raise on faster hardware.
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use "info" or higher in non-local environments.
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Database — PostgreSQL + PostGIS
# Host "postgres" is the compose service name; use 127.0.0.1 if running natively.
# ----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=spmis
DB_USERNAME=spmis
# CHANGE ME — set a strong password; must match POSTGRES_PASSWORD in compose env.
DB_PASSWORD=change-me-postgres

# ----------------------------------------------------------------------------
# Cache & Session — Redis
# REDIS_CLIENT=predis uses the pure-PHP client (no ext-redis needed).
# ----------------------------------------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Queue — RabbitMQ
# The worker container runs `php artisan queue:work rabbitmq`.
# ----------------------------------------------------------------------------
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=spmis
# CHANGE ME — must match RABBITMQ_DEFAULT_PASS in compose env.
RABBITMQ_PASSWORD=change-me-rabbitmq
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default

# ----------------------------------------------------------------------------
# CORS — strict allowlist (comma-separated origins, no wildcard)
# Set to the SPA origin(s) only.
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=true
CORS_MAX_AGE=0

# Sanctum stateful domains (SPA). Comma-separated, no scheme.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# ----------------------------------------------------------------------------
# Authentication security (MFA, lockout, token lifetimes) — see config/security.php
# ----------------------------------------------------------------------------
# Account lockout (FR-UAM-06): lock after N failed logins, with exponential backoff.
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DECAY_MINUTES=1
AUTH_LOCKOUT_MULTIPLIER=2
AUTH_LOCKOUT_MAX_MINUTES=60
# MFA (FR-UAM-04)
MFA_ISSUER="SP-MIS"
MFA_RECOVERY_CODE_COUNT=8
MFA_WINDOW=1
MFA_CHALLENGE_TTL_MINUTES=5
# Token lifetimes: idle timeout and absolute lifetime (minutes).
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_LIFETIME_MINUTES=480
# Per-user per-minute ceilings on the riskiest endpoint classes (SECURITY.md).
RATE_LIMIT_EXPORTS_PER_MINUTE=10
RATE_LIMIT_IMPORTS_PER_MINUTE=12

# ----------------------------------------------------------------------------
# Dev-only seeded admin (DevUserSeeder). LOCAL DEVELOPMENT ONLY — never used in
# production (the seeder skips production). CHANGE THESE for any shared env.
# ----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@spmis.local
SEED_ADMIN_PASSWORD=ChangeMe!Admin12345

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ----------------------------------------------------------------------------
# Backups & disaster recovery (NFR-AVAIL-01) — see docs/SCALE-AND-AVAILABILITY.md
# ----------------------------------------------------------------------------
# Offsite destination disk (config/filesystems.php). Use 's3' in production, in a
# DIFFERENT failure domain than the DB host. 'local' is dev/CI only (NOT offsite).
BACKUP_DISK=local
BACKUP_PATH=backups
# REQUIRED to run a backup (never written unencrypted). Generate: php artisan backup:keygen
# Store in the secret manager, SEPARATE from the backup destination credentials.
BACKUP_ENCRYPTION_KEY=
BACKUP_INCLUDE_DOCUMENTS=true
BACKUP_RETENTION_DAYS=30
# Recovery objectives (minutes): RPO 24h (daily backups), RTO 4h (restore budget).
BACKUP_RPO_MINUTES=1440
BACKUP_RTO_MINUTES=240
# Offsite object storage (when BACKUP_DISK=s3). Also used for shared documents at scale.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Structured JSON logs for a log aggregator (NFR-AVAIL-01). Add "json" to LOG_STACK
# in non-local environments; critical-level records are the alerting hook.
LOG_JSON_STREAM=php://stderr

# ----------------------------------------------------------------------------
# Mail (log driver by default; configure a real SMTP host per environment)
# ----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@spmis.local"
MAIL_FROM_NAME="${APP_NAME}"
