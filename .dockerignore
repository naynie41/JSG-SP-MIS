# Keep the build context lean and ensure NO secrets/state enter any image.
.git
.github
docs
**/.env
**/.env.*
!**/.env.example
**/node_modules
**/vendor
web/dist
api/storage/logs/*
api/storage/framework/cache/*
api/storage/framework/sessions/*
api/storage/framework/views/*
api/storage/app/private/*
**/*.md
docker-compose.yml
docker-compose.prod.yml
