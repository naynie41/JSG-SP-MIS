# =============================================================================
# SP-MIS PRODUCTION environment template.
#
# On the VPS:  cp .env.prod.example .env  → fill in real values → chmod 600 .env,
# owned by root. This ONE file feeds both docker compose (image tags, service
# passwords, TLS) AND the Laravel app containers (env_file). NEVER commit the real
# .env — only this example is in git. NO REAL SECRETS HERE.
# =============================================================================

# ---- Image source (GHCR) ----------------------------------------------------
# Lowercase GitHub owner/org that owns the packages, and the release tag to run.
# Redeploy/rollback = change IMAGE_TAG, then `pull && up -d` (see docs/DEPLOY.md).
GHCR_OWNER=your-github-owner
IMAGE_TAG=v1.0.0

# ---- Application ------------------------------------------------------------
APP_NAME="SP-MIS"
APP_ENV=production
APP_DEBUG=false
# Generate ONCE with `php artisan key:generate --show` and keep it stable — it
# protects encrypted columns (NIN/BVN/TOTP) and must never change with data present.
APP_KEY=
APP_URL=https://spmis.example.gov.ng
APP_LOCALE=en

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
# Structured JSON logs to stderr for the container/log aggregator (NFR-AVAIL-01).
LOG_STACK=json
LOG_LEVEL=info
LOG_JSON_STREAM=php://stderr

# ---- Database (PostgreSQL + PostGIS) ---------------------------------------
# DB_* are read by Laravel; POSTGRES_* configure the postgres container. Keep the
# DB_PASSWORD and POSTGRES_PASSWORD values IDENTICAL.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=spmis
DB_USERNAME=spmis
DB_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=spmis
POSTGRES_USER=spmis
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- Cache & Session (Redis) -----------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
# Used by BOTH the redis container (requirepass) and Laravel.
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ---- Queue (RabbitMQ) ------------------------------------------------------
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=spmis
RABBITMQ_PASSWORD=CHANGE_ME_strong_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default

# ---- CORS / Sanctum (SPA origin only) --------------------------------------
CORS_ALLOWED_ORIGINS=https://spmis.example.gov.ng
CORS_SUPPORTS_CREDENTIALS=true
SANCTUM_STATEFUL_DOMAINS=spmis.example.gov.ng

# ---- Auth security (see config/security.php) -------------------------------
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DECAY_MINUTES=1
AUTH_LOCKOUT_MAX_MINUTES=60
MFA_ISSUER="SP-MIS"
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_LIFETIME_MINUTES=480

# ---- Files & mail ----------------------------------------------------------
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.example
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="no-reply@spmis.example.gov.ng"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Backups & DR (NFR-AVAIL-01) — see docs/SCALE-AND-AVAILABILITY.md -------
# Offsite object store (a DIFFERENT failure domain than this VPS).
BACKUP_DISK=s3
BACKUP_PATH=backups
# `php artisan backup:keygen` → store in the secret manager, separate from AWS_*.
BACKUP_ENCRYPTION_KEY=
BACKUP_INCLUDE_DOCUMENTS=true
BACKUP_RETENTION_DAYS=30
BACKUP_RPO_MINUTES=1440
BACKUP_RTO_MINUTES=240
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=spmis-backups
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Data-protection lifecycle (NFR-PRV-01) — DPO-owned --------------------
PRIVACY_RETENTION_ENABLED=false
PRIVACY_PROCESSING_REQUIRES_CONSENT=false

# ---- Edge nginx (TLS) ------------------------------------------------------
NGINX_SERVER_NAME=spmis.example.gov.ng
# Certbot layout by default; override for a provided cert. Paths are INSIDE the
# nginx container (see TLS_DIR mount below).
NGINX_SSL_CERTIFICATE=/etc/letsencrypt/live/spmis.example.gov.ng/fullchain.pem
NGINX_SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/spmis.example.gov.ng/privkey.pem
NGINX_CLIENT_MAX_BODY_SIZE=50M
# Host cert dir mounted read-only into nginx (Let's Encrypt or your provided cert).
TLS_DIR=/etc/letsencrypt
# Host webroot for ACME http-01 challenge renewals.
ACME_WEBROOT=./acme
