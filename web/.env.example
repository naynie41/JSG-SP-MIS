# =============================================================================
# SP-MIS web (React/Vite) — environment template
# Copy to .env (`cp .env.example .env`). Only VITE_-prefixed vars are exposed
# to the browser bundle, so never put secrets here.
# =============================================================================

# Base URL of the SP-MIS API (no trailing slash). The app calls `${VITE_API_BASE_URL}/health` etc.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Display name used in the UI.
VITE_APP_NAME="SP-MIS"
